function renderSpider(games){
  const canvas=document.getElementById('d-spider-chart');if(!canvas)return;
  const ctx=canvas.getContext('2d'),W=180,H=180,cx=90,cy=95,R=65;
  ctx.clearRect(0,0,W,H);
  const st=computeStats(games);
  const axes=[
    {label:'KDA',val:st.avgKda==='—'?0:Math.min(parseFloat(st.avgKda)/6,1)},
    {label:'CS/min',val:st.avgCs==='—'?0:Math.min(parseFloat(st.avgCs)/10,1)},
    {label:'Vision',val:st.avgVs==='—'?0:Math.min(st.avgVs/40,1)},
    {label:'WR',val:st.wr!==null?st.wr/100:0},
    {label:'DMG',val:st.avgDmg==='—'?0:Math.min(parseFloat(st.avgDmg)/30,1)},
  ];
  const n=axes.length;
  const angle=i=>(i/n)*Math.PI*2-Math.PI/2;
  for(let lvl=1;lvl<=4;lvl++){ctx.beginPath();for(let i=0;i<n;i++){const a=angle(i),r=(R/4)*lvl;i===0?ctx.moveTo(cx+Math.cos(a)*r,cy+Math.sin(a)*r):ctx.lineTo(cx+Math.cos(a)*r,cy+Math.sin(a)*r);}ctx.closePath();ctx.strokeStyle='rgba(40,55,75,0.9)';ctx.lineWidth=1;ctx.stroke();}
  for(let i=0;i<n;i++){
    const a=angle(i);
    ctx.beginPath();ctx.moveTo(cx,cy);ctx.lineTo(cx+Math.cos(a)*R,cy+Math.sin(a)*R);ctx.strokeStyle='rgba(40,55,75,0.6)';ctx.lineWidth=1;ctx.stroke();
    const lx=cx+Math.cos(a)*(R+16),ly=cy+Math.sin(a)*(R+16);
    ctx.fillStyle='rgba(224,230,237,0.9)';ctx.font="bold 10px 'Share Tech Mono'";ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(axes[i].label,lx,ly);
    const pct=Math.round(axes[i].val*100);
    ctx.fillStyle='rgba(200,155,60,0.85)';ctx.font="bold 9px 'Share Tech Mono'";ctx.fillText(pct+'%',lx,ly+12);
  }
  ctx.beginPath();for(let i=0;i<n;i++){const a=angle(i),r=axes[i].val*R;i===0?ctx.moveTo(cx+Math.cos(a)*r,cy+Math.sin(a)*r):ctx.lineTo(cx+Math.cos(a)*r,cy+Math.sin(a)*r);}
  ctx.closePath();ctx.fillStyle='rgba(200,155,60,0.2)';ctx.fill();ctx.strokeStyle='#c89b3c';ctx.lineWidth=2;ctx.shadowColor='rgba(200,155,60,0.4)';ctx.shadowBlur=5;ctx.stroke();ctx.shadowBlur=0;
  for(let i=0;i<n;i++){const a=angle(i),r=axes[i].val*R;ctx.beginPath();ctx.arc(cx+Math.cos(a)*r,cy+Math.sin(a)*r,4,0,Math.PI*2);ctx.fillStyle='#c89b3c';ctx.fill();}
  const labelsEl=document.getElementById('d-spider-labels');if(labelsEl)labelsEl.innerHTML='';
}

/* ════════════ PROGRESSION TAB ════════════ */
function renderProgressionTab(){
  const games=gg(),prof=ap();
  function inj(id,html){const el=document.getElementById(id);if(el)el.innerHTML=html;}
  const canvas=document.getElementById('d-lp-full-chart');
  if(canvas&&canvas.parentElement){
    const W=canvas.parentElement.clientWidth-26,H=250;
    canvas.width=W;canvas.height=H;const ctx=canvas.getContext('2d');ctx.clearRect(0,0,W,H);
    if(games.length>0){
      const allG=[...games].reverse();
      const initLP=prof?.setup?.initialRank?r2lp(prof.setup.initialRank.rank,prof.setup.initialRank.div,prof.setup.initialRank.lp):0;
      const points=[initLP,...allG.map(g=>r2lp(g.rankAfter.rank,g.rankAfter.div,g.rankAfter.lp))];
      drawLine(ctx,W,H,points,allG);
    }else{ctx.fillStyle='rgba(224,230,237,0.4)';ctx.font="12px 'Share Tech Mono'";ctx.textAlign='center';ctx.fillText('Aucune partie',W/2,H/2);}
  }
  const dayMap={};
  games.forEach(g=>{const day=g.date?.split(' ')[0]||'?';if(!dayMap[day])dayMap[day]={wins:0,total:0};dayMap[day].total++;if(g.result==='win')dayMap[day].wins++;});
  const days=Object.entries(dayMap).slice(-8);
  inj('d-wr-sessions',days.length?days.map(([day,d])=>{const wr=Math.round(d.wins/d.total*100),wrc=wr>=50?'var(--win)':'var(--loss)';return`<div class="stat-row-item"><span class="sri-label">${day}</span><div style="display:flex;align-items:center;gap:10px"><div class="cbar-wrap" style="width:80px"><div class="cbar" style="width:${wr}%;background:${wrc}"></div></div><span class="sri-val" style="color:${wrc};font-size:15px">${wr}%</span><span style="font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--text3)">${d.total}G</span></div></div>`;}).join(''):nodata('Aucune données'));
  const winG=games.filter(g=>g.result==='win'),lossG=games.filter(g=>g.result==='loss');
  const avgWin=winG.length>0?Math.round(winG.reduce((s,g)=>s+g.lpChange,0)/winG.length):0;
  const avgLoss=lossG.length>0?Math.round(Math.abs(lossG.reduce((s,g)=>s+g.lpChange,0)/lossG.length)):0;
  const ratio=avgLoss>0?(avgWin/avgLoss).toFixed(2):'∞';
  inj('d-lp-avg-stats',[sri('LP moyen gagné','+'+avgWin,'win'),sri('LP moyen perdu','-'+avgLoss,'loss'),sri('Ratio gain/perte',ratio,'accent'),sri('Victoires totales',winG.length,'win'),sri('Défaites totales',lossG.length,'loss')].join(''));
  const hourMap=Array(8).fill(null).map(()=>({win:0,loss:0}));
  games.forEach(g=>{const ts=new Date(g.ts||0);const slot=Math.floor(ts.getHours()/3);if(g.result==='win')hourMap[slot].win++;else if(g.result==='loss')hourMap[slot].loss++;});
  const slots=['0-3h','3-6h','6-9h','9-12h','12-15h','15-18h','18-21h','21-24h'];
  inj('d-time-heatmap',hourMap.map((d,i)=>{const total=d.win+d.loss;const wr=total>0?Math.round(d.win/total*100):null;const wrc=wr>=50?'var(--win)':wr!==null?'var(--loss)':'var(--text3)';return`<div class="stat-row-item"><span class="sri-label" style="min-width:60px">${slots[i]}</span><div style="display:flex;align-items:center;gap:10px"><div class="cbar-wrap" style="width:70px"><div class="cbar" style="width:${wr||0}%;background:${wrc}"></div></div><span style="font-family:'Share Tech Mono',monospace;font-size:11px;color:${wrc}">${wr!==null?wr+'%':'—'}</span><span style="font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--text3)">${total}G</span></div></div>`;}).join(''));
  let peakLP=prof?.setup?.initialRank?r2lp(prof.setup.initialRank.rank,prof.setup.initialRank.div,prof.setup.initialRank.lp):0;
  [...games].reverse().forEach(g=>{const lp=r2lp(g.rankAfter.rank,g.rankAfter.div,g.rankAfter.lp);peakLP=Math.max(peakLP,lp);});
  const peakRank=lp2r(peakLP);const peakCol=RC[peakRank.rank];
  const currLPTotal=prof?r2lp(prof.currentRank.rank,prof.currentRank.div,prof.currentRank.lp):0;
  const diffFromPeak=currLPTotal-peakLP;
  inj('d-peak-stats',`<div style="margin-bottom:12px"><div class="slabel">Peak atteint</div><div style="font-family:'Rajdhani',sans-serif;font-size:28px;font-weight:700;color:${peakCol}">${rs(peakRank)}</div><div style="font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--text2)">${peakRank.lp} LP</div></div>${[sri('Distance au peak',(diffFromPeak>=0?'+':'')+diffFromPeak+' LP',diffFromPeak>=0?'win':'loss'),sri('Rang initial',prof?.setup?.initialRank?rs(prof.setup.initialRank):'—')].join('')}`);
}

/* ════════════ MOBILE HISTORY ════════════ */
function renderMobileHistory(){
  const list=document.getElementById('m-history-list');if(!list)return;
  const prof=ap();let games=prof?[...prof.games]:[];
  if(S.mobileFilter==='win')games=games.filter(g=>g.result==='win');
  else if(S.mobileFilter==='loss')games=games.filter(g=>g.result==='loss');
  if(!games.length){list.innerHTML='<div class="empty-state"><div class="empty-icon">⚔</div><div>Aucune partie</div></div>';return;}
  list.innerHTML=games.map(g=>{
    const lpStr=(g.lpChange>0?'+':'')+g.lpChange,lpCls=g.lpChange>0?'pos':g.lpChange<0?'neg':'zero';
    const rankAfterStr=g.rankAfter?rs(g.rankAfter):'—',rankCol=g.rankAfter?RC[g.rankAfter.rank]:'#c89b3c';
    const kdaStr=`${g.k}/${g.d}/${g.a}`,ratio=g.kdaRatio===Infinity?'∞':(g.kdaRatio?.toFixed(1)||'—');
    const kdaCls=g.kdaRatio>=4?'kda-p':g.kdaRatio>=2?'kda-g':'kda-b';
    const icon=g.result==='win'?'✅':'❌';
    const extra=[];
    if(g.csm)extra.push(g.csm+'cs/m');if(g.kp!==null&&g.kp!==undefined)extra.push('KP'+g.kp+'%');if(g.note)extra.push('★'+g.note);if(g.matchup)extra.push('vs '+g.matchup);
    return`<div class="game-card-m ${g.result}">
      <div class="gc-left"><div style="font-size:16px">${icon}</div><div style="font-size:10px;color:var(--text2)">${g.role}</div>${g.note?`<div style="font-size:10px;color:${noteColor(g.note)}">★${g.note}</div>`:'&nbsp;'}</div>
      <div><div class="gc-champ">${g.champion}</div><div class="gc-meta ${kdaCls}">${kdaStr} · <b>${ratio}</b></div>${extra.length?`<div class="gc-meta" style="color:var(--text3)">${extra.join(' · ')}</div>`:''}<div class="gc-meta" style="color:var(--text3)">${g.date}</div>${g.comment?`<div class="gc-comment">${g.comment}</div>`:''}</div>
      <div class="gc-right"><div class="gc-lp ${lpCls}">${lpStr}</div><div class="gc-rank" style="color:${rankCol}">${rankAfterStr}</div>
        <div class="gc-actions">
          ${g.screenshot?`<button class="gc-img" onclick="openImg('${g.screenshot.substring(0,30)}...')" onclick="openImg(getScreenshot(${g.id}))">🖼</button>`:''}
          <button class="gc-edit" onclick="openEditModal(${g.id})">✏</button>
          <button class="gc-del" onclick="deleteGame(${g.id})">✕</button>
        </div>
      </div>
    </div>`;
  }).join('');
  games.forEach(g=>{if(!g.screenshot)return;const btn=list.querySelector(`[data-img="${g.id}"]`);if(btn)btn.onclick=()=>openImg(g.screenshot);});
}

/* ════════════ DESKTOP TABLE ════════════ */
function renderDesktopTable(){
  const tbody=document.getElementById('d-tbody');if(!tbody)return;
  const emptyEl=document.getElementById('d-empty');if(!emptyEl)return;
  const prof=ap();let games=prof?[...prof.games]:[];
  if(S.desktopFilter==='win')games=games.filter(g=>g.result==='win');
  else if(S.desktopFilter==='loss')games=games.filter(g=>g.result==='loss');
  tbody.innerHTML='';emptyEl.style.display=games.length===0?'block':'none';
  const allG=prof?prof.games:[];
  games.forEach(g=>{
    const lpStr=(g.lpChange>0?'+':'')+g.lpChange,lpCls=g.lpChange>0?'pos':g.lpChange<0?'neg':'zero';
    const rankAfterStr=g.rankAfter?rs(g.rankAfter):'—',rankCol=g.rankAfter?RC[g.rankAfter.rank]:'#c89b3c';
    const kdaStr=`${g.k}/${g.d}/${g.a}`,ratio=g.kdaRatio===Infinity?'∞':(g.kdaRatio?.toFixed(1)||'—');
    const kdaCls=g.kdaRatio>=4?'kda-p':g.kdaRatio>=2?'kda-g':'kda-b';
    const num=allG.length-allG.indexOf(g);
    const kpStr=g.kp!==null&&g.kp!==undefined?g.kp+'%':'—';
    const noteStr=g.note||'—';
    const noteCol=g.note?noteColor(g.note):'var(--text3)';
    const tr=document.createElement('tr');
    const screenshot=g.screenshot;
    tr.innerHTML=`
      <td style="color:var(--text3);font-family:'Share Tech Mono',monospace;font-size:10px">${num}</td>
      <td style="color:var(--text3);font-family:'Share Tech Mono',monospace;font-size:10px">${g.date}</td>
      <td style="font-weight:600;color:var(--white);font-size:13px">${g.champion}</td>
      <td style="color:var(--text2);font-size:12px">${g.matchup?'vs '+g.matchup:'—'}</td>
      <td style="color:var(--text2);font-size:12px">${g.role}</td>
      <td><span class="result-badge ${g.result}">${g.result==='win'?'WIN':'LOSS'}</span></td>
      <td><span class="lpc ${lpCls}">${lpStr}</span></td>
      <td><span class="rank-badge" style="color:${rankCol};border-color:${rankCol}">${rankAfterStr}</span></td>
      <td class="${kdaCls}" style="font-family:'Share Tech Mono',monospace;font-size:11px">${kdaStr}</td>
      <td style="font-family:'Share Tech Mono',monospace;font-size:11px;color:${kpColor(g.kp)}">${kpStr}</td>
      <td style="color:${noteCol};font-family:'Rajdhani',sans-serif;font-size:15px;font-weight:700">${noteStr}</td>
      <td style="font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--text2)">${g.csm||'—'}</td>
      <td style="font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--text2)">${g.vs||'—'}</td>
      <td style="font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--text2)">${g.dmg||'—'}</td>
      <td class="td-comment" title="${g.draft||''}" style="color:#5bc4e8">${g.draft||'—'}</td>
      <td class="td-comment" title="${g.comment||''}">${g.comment||'—'}</td>
      <td style="display:flex;align-items:center;gap:4px">
        ${screenshot?`<button class="td-img" id="img-btn-${g.id}" title="Voir screenshot">🖼</button>`:''}
        <button class="td-edit" onclick="openEditModal(${g.id})" title="Modifier">✏</button>
        <button class="td-del" onclick="deleteGame(${g.id})" title="Supprimer">✕</button>
      </td>`;
    tbody.appendChild(tr);
    if(screenshot){
      const imgBtn=tr.querySelector(`#img-btn-${g.id}`);
      if(imgBtn)imgBtn.onclick=()=>openImg(screenshot);
    }
  });
}

/* ════════════ PROFILE CARDS ════════════ */
function renderProfileCards(){
  ['d','m'].forEach(px=>{
    const container=document.getElementById(px+'-profile-cards');if(!container)return;
    container.innerHTML='';
    S.profiles.forEach(prof=>{
      const isActive=prof.id===S.activeProfileId,r=prof.currentRank;
      const st=computeStats(prof.games);
      const card=document.createElement('div');
      card.className='profile-card'+(isActive?' active-profile':'');
      card.innerHTML=`<button class="profile-del" onclick="event.stopPropagation();deleteProfile('${prof.id}')">✕</button>
        <div class="profile-card-name">${prof.setup?.name||'—'}</div>
        <div class="profile-card-sub">${prof.setup?.queue||''} · ${prof.setup?.season||''}</div>
        <div class="pc-stats">
          <div class="pc-s"><div class="pc-v" style="color:${r?RC[r.rank]:'var(--accent)'}">${r?rs(r):'—'}</div><div class="pc-l">Rang</div></div>
          <div class="pc-s"><div class="pc-v">${prof.games.length}</div><div class="pc-l">Parties</div></div>
          <div class="pc-s"><div class="pc-v" style="color:${st.wr>=50?'var(--win)':st.wr!==null?'var(--loss)':'var(--white)'}">${st.wr!==null?st.wr+'%':'—%'}</div><div class="pc-l">WR</div></div>
        </div>${isActive?'<div style="margin-top:8px;font-family:\'Share Tech Mono\',monospace;font-size:10px;color:var(--accent);letter-spacing:1px">● ACTIF</div>':''}`;
      card.addEventListener('click',()=>{if(!isActive)switchProfile(prof.id);else openSetup(prof.id);});
      container.appendChild(card);
    });
    if(px==='d'){const a=document.createElement('div');a.className='new-profile-card';a.innerHTML='<span style="font-size:20px">+</span> Nouveau compte';a.onclick=openNewProfile;container.appendChild(a);}
  });
  const bar=document.getElementById('m-profile-bar');if(!bar)return;
  bar.innerHTML='';
  S.profiles.forEach(prof=>{const btn=document.createElement('button');btn.className='profile-chip'+(prof.id===S.activeProfileId?' active':'');btn.textContent=prof.setup?.name?.split('#')[0]||'—';btn.onclick=()=>switchProfile(prof.id);bar.appendChild(btn);});
  const addBtn=document.createElement('button');addBtn.className='profile-add-btn';addBtn.textContent='+';addBtn.onclick=openNewProfile;bar.appendChild(addBtn);
}

/* ════════════ MASTER RENDER ════════════ */
function render(){
  renderHeader();
  renderRankCards();
  renderDesktopTable();
  renderMobileHistory();
  renderStats();
  renderMobileStats();
  renderProfileCards();
}

/* ════════════ INIT ════════════ */
(function(){
  try{
    ['mlt_v1','loltrack_v5','loltrack_v4','loltrack_v3'].forEach(key=>{
      if(S.profiles.length>0)return;
      const old=localStorage.getItem(key);if(!old)return;
      const o=JSON.parse(old);
      if(o.profiles&&o.profiles.length>0){S={...o};save();return;}
      if(o.setup){const np={id:'p_mig',setup:o.setup,games:(o.games||[]).map(g=>({...g,ts:g.ts||Date.now()})),currentRank:o.currentRank||o.setup?.initialRank||{rank:'Gold',div:'IV',lp:0}};S.profiles.push(np);S.activeProfileId=np.id;save();}
    });
  }catch(e){}
})();

if(S.profiles.length===0)openSetup();
else{if(!S.activeProfileId)S.activeProfileId=S.profiles[0].id;render();setTimeout(()=>renderChart(),80);}

window.addEventListener('resize',()=>{
  renderHeader();
  renderChart('d');
  renderChart('m');
  const dt=document.querySelector('.d-tab-content.active');
  if(dt?.id==='dtab-progression')renderProgressionTab();
});

document.getElementById('setup-modal').addEventListener('click',function(e){if(e.target===this&&S.profiles.length>0)this.classList.add('hidden');});
</script>
