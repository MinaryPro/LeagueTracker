/* ════════════ RENDER RANK CARDS ════════════ */
function renderRankCards(){
  const prof=ap();if(!prof||!prof.currentRank)return;
  const r=prof.currentRank,col=RC[r.rank],glow=RG[r.rank];
  const games=prof.games,st=computeStats(games);
  const lpPct=r.div?r.lp:Math.min(100,r.lp/10);
  const goalRank=prof.setup?.goalRank||'Platinum',goalCol=RC[goalRank];
  const currTotal=r2lp(r.rank,r.div,r.lp),goalTotal=r2lp(goalRank,'IV',0),missing=Math.max(0,goalTotal-currTotal);
  let goalPct=0;
  if(prof.setup?.initialRank){const it=r2lp(prof.setup.initialRank.rank,prof.setup.initialRank.div,prof.setup.initialRank.lp);const rng=goalTotal-it;goalPct=rng>0?Math.max(0,Math.min(100,(currTotal-it)/rng*100)):100;}
  ['m','d'].forEach(px=>{
    function $(id){return document.getElementById(px+'-'+id);}
    const rc=$('rank-card');if(rc)rc.style.setProperty('--bar',col);
    const rb=$('rank-big');if(rb){rb.textContent=r.div?`${r.rank} ${r.div}`:r.rank;rb.style.color=col;rb.style.textShadow=`0 0 14px ${glow}`;}
    const rl=$('rank-lp');if(rl)rl.textContent=r.lp+' LP';
    const bar=$('lp-bar');if(bar){bar.style.width=lpPct+'%';bar.style.background=`linear-gradient(90deg,${col},${glow})`;bar.style.boxShadow=`0 0 6px ${glow}`;}
    const ss={games:games.length,wr:st.wr!==null?st.wr+'%':'—%',lpnet:(st.lpNet>=0?'+':'')+st.lpNet,kda:st.avgKda,cs:st.avgCs,kp:st.avgKp!=='—'?st.avgKp+'%':'—%',note:st.avgNote,streak:st.streakStr};
    Object.entries(ss).forEach(([k,v])=>{const el=document.getElementById(px+'-s-'+k);if(!el)return;el.textContent=v;if(k==='wr')el.style.color=st.wr>=50?'var(--win)':st.wr!==null?'var(--loss)':'var(--white)';if(k==='lpnet')el.style.color=st.lpNet>=0?'var(--win)':'var(--loss)';});
    const sd=$('streak-dots');if(sd){sd.innerHTML='';[...games].slice(0,10).reverse().forEach(g=>{const dot=document.createElement('div');dot.className=`sdot ${g.result}`;dot.title=`${g.champion} (${g.lpChange>0?'+':''}${g.lpChange} LP)`;sd.appendChild(dot);});}
    const gc=$('goal-card');if(gc)gc.style.setProperty('--bar',goalCol);
    const gl=$('goal-label');if(gl){gl.textContent=goalRank;gl.style.color=goalCol;}
    const gm=$('goal-missing');if(gm)gm.textContent=missing>0?`${missing} LP restants`:'✓ Atteint !';
    const gb=$('goal-bar');if(gb){gb.style.width=goalPct+'%';gb.style.background=`linear-gradient(90deg,${goalCol},${RG[goalRank]})`;gb.style.boxShadow=`0 0 5px ${RG[goalRank]}`;}
  });
}

/* ════════════ CHARTS ════════════ */
function renderChart(target){
  const targets=target?[target]:['m','d'],prof=ap();
  targets.forEach(px=>{
    const canvas=document.getElementById(px+'-lp-chart');if(!canvas||!canvas.parentElement)return;
    const W=canvas.parentElement.clientWidth-26,H=parseInt(canvas.getAttribute('height'))||90;
    canvas.width=W;canvas.height=H;const ctx=canvas.getContext('2d');ctx.clearRect(0,0,W,H);
    const games=prof?[...prof.games].reverse():[];
    if(games.length===0){ctx.fillStyle='rgba(224,230,237,0.4)';ctx.font="12px 'Share Tech Mono'";ctx.textAlign='center';ctx.fillText('Ajoutez des parties pour voir la progression',W/2,H/2);return;}
    const initLP=prof?.setup?.initialRank?r2lp(prof.setup.initialRank.rank,prof.setup.initialRank.div,prof.setup.initialRank.lp):0;
    const points=[initLP,...games.map(g=>r2lp(g.rankAfter.rank,g.rankAfter.div,g.rankAfter.lp))];
    drawLine(ctx,W,H,points,games);
  });
}
function drawLine(ctx,W,H,points,games){
  const minLP=Math.min(...points)-10,maxLP=Math.max(...points)+10,range=maxLP-minLP||1;
  const pad={l:90,r:15,t:15,b:15},gW=W-pad.l-pad.r,gH=H-pad.t-pad.b;
  const toX=i=>pad.l+(points.length>1?i/(points.length-1):0.5)*gW;
  const toY=v=>pad.t+gH-((v-minLP)/range)*gH;
  
  ctx.strokeStyle='rgba(40,55,75,0.8)';ctx.lineWidth=1;
  ctx.fillStyle='rgba(168, 184, 200, 0.7)';
  ctx.font="10px 'Share Tech Mono'";
  ctx.textAlign="right";
  ctx.textBaseline="middle";

  for(let i=0;i<=4;i++){
    const val = minLP + (range * (4-i)/4);
    const y=pad.t+(i/4)*gH;
    ctx.beginPath();ctx.moveTo(pad.l,y);ctx.lineTo(W-pad.r,y);ctx.stroke();
    const rObj = lp2r(val);
    let lbl = rObj.div ? `${rObj.rank} ${rObj.div}` : rObj.rank;
    ctx.fillText(lbl, pad.l - 8, y);
  }

  const grad=ctx.createLinearGradient(0,pad.t,0,H-pad.b);
  grad.addColorStop(0,'rgba(200,155,60,0.18)');grad.addColorStop(1,'rgba(200,155,60,0.01)');
  ctx.beginPath();ctx.moveTo(toX(0),toY(points[0]));
  points.forEach((p,i)=>{if(i>0)ctx.lineTo(toX(i),toY(p));});
  ctx.lineTo(toX(points.length-1),H-pad.b);ctx.lineTo(toX(0),H-pad.b);ctx.closePath();ctx.fillStyle=grad;ctx.fill();
  ctx.beginPath();ctx.moveTo(toX(0),toY(points[0]));
  points.forEach((p,i)=>{if(i>0)ctx.lineTo(toX(i),toY(p));});
  ctx.strokeStyle='#c89b3c';ctx.lineWidth=2;ctx.shadowColor='rgba(200,155,60,0.5)';ctx.shadowBlur=5;ctx.stroke();ctx.shadowBlur=0;
  if(games)points.forEach((p,i)=>{if(i===0)return;const g=games[i-1];ctx.beginPath();ctx.arc(toX(i),toY(p),4,0,Math.PI*2);ctx.fillStyle=g.result==='win'?'#2ecc71':'#e74c3c';ctx.fill();});
}

/* ════════════ SHARED HTML BUILDERS ════════════ */
function champHTML(games,limit){
  const cm={};
  games.forEach(g=>{if(!g.champion||g.champion==='—')return;if(!cm[g.champion])cm[g.champion]={games:0,wins:0,kdaSum:0,kdaN:0,csSum:0,csN:0,noteSum:0,noteN:0,kpSum:0,kpN:0};const d=cm[g.champion];d.games++;if(g.result==='win')d.wins++;if(isFinite(g.kdaRatio)){d.kdaSum+=g.kdaRatio;d.kdaN++;}if(g.csm){d.csSum+=g.csm;d.csN++;}if(g.note){d.noteSum+=g.note;d.noteN++;}if(g.kp!==null&&g.kp!==undefined){d.kpSum+=g.kp;d.kpN++;}});
  const champs=Object.entries(cm).sort((a,b)=>b[1].games-a[1].games).slice(0,limit||8);
  const maxG=champs[0]?.[1].games||1;
  if(!champs.length)return nodata();
  return champs.map(([name,d])=>{
    const wr=Math.round(d.wins/d.games*100),wrc=wr>=50?'var(--win)':'var(--loss)';
    const kda=d.kdaN>0?(d.kdaSum/d.kdaN).toFixed(1):'—';
    const cs=d.csN>0?(d.csSum/d.csN).toFixed(1):'—';
    const note=d.noteN>0?(d.noteSum/d.noteN).toFixed(1):'—';
    const kp=d.kpN>0?Math.round(d.kpSum/d.kpN)+'%':'—';
    return`<div style="display:flex;align-items:center;gap:12px;margin-bottom:10px">
      <div style="font-weight:600;color:var(--white);min-width:85px;font-size:14px">${name}</div>
      <div class="cbar-wrap"><div class="cbar" style="width:${(d.games/maxG)*100}%;background:var(--accent)"></div></div>
      <div style="font-family:'Share Tech Mono',monospace;font-size:12px;color:${wrc};min-width:190px;text-align:right">${d.games}G · ${wr}%WR · ${kda}KDA · ${cs}cs/m · KP${kp} · ★${note}</div>
    </div>`;
  }).join('');
}
function matchupHTML(games,limit){
  const mm={};games.forEach(g=>{if(!g.matchup)return;const k=g.matchup.trim();if(!k)return;if(!mm[k])mm[k]={games:0,wins:0};mm[k].games++;if(g.result==='win')mm[k].wins++;});
  const list=Object.entries(mm).sort((a,b)=>b[1].games-a[1].games).slice(0,limit||8);
  const maxG=list[0]?.[1].games||1;
  if(!list.length)return nodata('Aucun matchup');
  return list.map(([name,d])=>{
    const wr=Math.round(d.wins/d.games*100),wrc=wr>=50?'var(--win)':'var(--loss)';
    return`<div style="display:flex;align-items:center;gap:12px;margin-bottom:10px">
      <div style="font-weight:600;color:var(--white);min-width:85px;font-size:14px">vs ${name}</div>
      <div class="cbar-wrap"><div class="cbar" style="width:${(d.games/maxG)*100}%;background:${wrc}"></div></div>
      <div style="font-family:'Share Tech Mono',monospace;font-size:12px;color:${wrc};min-width:90px;text-align:right">${d.games}G · ${wr}%WR</div>
    </div>`;
  }).join('');
}
function roleHTML(games){
  const rm={};games.forEach(g=>{if(!rm[g.role])rm[g.role]={games:0,wins:0};rm[g.role].games++;if(g.result==='win')rm[g.role].wins++;});
  const roles=Object.entries(rm).sort((a,b)=>b[1].games-a[1].games);
  if(!roles.length)return nodata();
  return roles.map(([role,d])=>{
    const wr=Math.round(d.wins/d.games*100),wrc=wr>=50?'var(--win)':'var(--loss)';
    return`<div style="display:flex;align-items:center;gap:12px;margin-bottom:10px">
      <div style="font-weight:600;color:var(--white);min-width:75px;font-size:14px">${role}</div>
      <div class="cbar-wrap"><div class="cbar" style="width:${wr}%;background:${wrc}"></div></div>
      <div style="font-family:'Share Tech Mono',monospace;font-size:12px;color:${wrc};min-width:85px;text-align:right">${d.games}G · ${wr}%WR</div>
    </div>`;
  }).join('');
}
function nodata(msg='Aucune partie'){return`<div style="color:var(--text3);font-family:'Share Tech Mono',monospace;font-size:12px;padding:10px 0">${msg}</div>`;}
function sri(label,val,cls=''){return`<div class="stat-row-item"><span class="sri-label">${label}</span><span class="sri-val ${cls}">${val}</span></div>`;}

