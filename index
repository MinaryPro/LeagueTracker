<script>
/* ════════════ CONSTANTS ════════════ */
const RANKS=['Iron','Bronze','Silver','Gold','Platinum','Emerald','Diamond','Master','Grandmaster','Challenger'];
const DIVS=['IV','III','II','I'];
const RC={Iron:'#7c7c7c',Bronze:'#8c4a1e',Silver:'#8fa3b1',Gold:'#c89b3c',Platinum:'#3cb8a8',Emerald:'#2ecc71',Diamond:'#5bc4e8',Master:'#9b59b6',Grandmaster:'#e74c3c',Challenger:'#f0e6c8'};
const RG={Iron:'rgba(124,124,124,0.4)',Bronze:'rgba(140,74,30,0.4)',Silver:'rgba(143,163,177,0.4)',Gold:'rgba(200,155,60,0.4)',Platinum:'rgba(60,184,168,0.4)',Emerald:'rgba(46,204,113,0.4)',Diamond:'rgba(91,196,232,0.4)',Master:'rgba(155,89,182,0.4)',Grandmaster:'rgba(231,76,60,0.4)',Challenger:'rgba(240,230,200,0.4)'};

function noteColor(v){if(v>=8)return'var(--win)';if(v>=6)return'var(--accent)';if(v>=4)return'var(--text)';return'var(--loss)';}
function kpColor(v){if(v>=70)return'var(--win)';if(v>=50)return'var(--accent)';if(v>=35)return'var(--text)';return'var(--loss)';}

/* ════════════ STATE ════════════ */
let S={profiles:[],activeProfileId:null,mobileFilter:'all',desktopFilter:'all',formResult:'win'};
function load(){try{const s=localStorage.getItem('mlt_v1');if(s)S=JSON.parse(s);}catch(e){}}
function save(){localStorage.setItem('mlt_v1',JSON.stringify(S));}
load();
function ap(){return S.profiles.find(p=>p.id===S.activeProfileId)||S.profiles[0]||null;}
function gg(){return ap()?ap().games:[];}

let pendingScreenshot=null;

/* ════════════ LP MATH ════════════ */
function r2lp(rank,div,lp){
  const m=['Master','Grandmaster','Challenger'].includes(rank);
  const ri=RANKS.indexOf(rank);
  const di=m?0:DIVS.indexOf(div);
  return ri*400+(m?0:di*100)+parseInt(lp||0);
}

function lp2r(t){
  if(t<0)t=0;
  const ri=Math.min(Math.floor(t/400),RANKS.length-1);
  const rank=RANKS[ri];
  if(['Master','Grandmaster','Challenger'].includes(rank))return{rank,div:null,lp:t-ri*400};
  const rem=t-ri*400;
  const di=Math.min(Math.floor(rem/100),3);
  return{rank,div:DIVS[di],lp:rem-di*100};
}

function rs(r){return r&&r.div?`${r.rank} ${r.div}`:r?r.rank:'—';}

/* ════════════ SAVE / RESTORE ════════════ */
function exportData(){
  const data=JSON.stringify(S,null,2);
  const blob=new Blob([data],{type:'application/json'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');
  a.href=url;a.download='minary-league-backup.json';a.click();
  URL.revokeObjectURL(url);
}
function importData(){document.getElementById('import-file').click();}
function handleImport(e){
  const file=e.target.files[0];if(!file)return;
  const reader=new FileReader();
  reader.onload=ev=>{try{const d=JSON.parse(ev.target.result);if(!d.profiles)throw new Error('Format invalide');if(!confirm('Restaurer ce fichier ? Les données actuelles seront écrasées.'))return;S=d;save();render();setTimeout(()=>renderChart(),80);alert('Restauration réussie !');}catch(err){alert('Fichier invalide : '+err.message);}};
  reader.readAsText(file);
  e.target.value='';
}

/* ════════════ SCREENSHOT ════════════ */
let editPendingScreenshot=null;
function handleScreenshot(event,src){
  const file=event.target.files[0];if(!file)return;
  const reader=new FileReader();
  reader.onload=ev=>{
    pendingScreenshot=ev.target.result;
    const prev=document.getElementById(src+'-screenshot-preview');
    if(prev)prev.innerHTML=`<img src="${pendingScreenshot}" style="height:40px;border-radius:4px;border:1px solid var(--border2);cursor:pointer" onclick="openImg('${pendingScreenshot}')"/>`;
  };
  reader.readAsDataURL(file);event.target.value='';
}
function handleEditScreenshot(event){
  const file=event.target.files[0];if(!file)return;
  const reader=new FileReader();
  reader.onload=ev=>{
    editPendingScreenshot=ev.target.result;
    const prev=document.getElementById('e-screenshot-preview');
    if(prev)prev.innerHTML=`<img src="${editPendingScreenshot}" style="height:40px;border-radius:4px;border:1px solid var(--border2);cursor:pointer" onclick="openImg('${editPendingScreenshot}')"/> <span style="color:var(--win);font-size:11px">Nouvelle image chargée</span>`;
  };
  reader.readAsDataURL(file);event.target.value='';
}
function openImg(src){
  document.getElementById('img-modal-src').src=src;
  document.getElementById('img-modal').classList.remove('hidden');
}

/* ════════════ NAV ════════════ */
let curMPage='home';
function mGoPage(p){
  document.querySelectorAll('.mpage').forEach(el=>el.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(el=>el.classList.remove('active'));
  document.getElementById('mpage-'+p).classList.add('active');
  document.getElementById('mnav-'+p).classList.add('active');
  curMPage=p;document.getElementById('mobile-pages').scrollTop=0;
  if(p==='home')renderChart('m');
  if(p==='history')renderMobileHistory();
  if(p==='stats'){renderMobileStats();}
  if(p==='profil')renderProfileCards();
}
function mGoSubTab(t,btn){
  document.querySelectorAll('.m-tab').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.m-tab-content').forEach(c=>c.classList.remove('active'));
  btn.classList.add('active');document.getElementById('m-sub-'+t).classList.add('active');
}
function dGoTab(t,btn){
  document.querySelectorAll('.d-tab-content').forEach(el=>el.classList.remove('active'));
  document.querySelectorAll('.d-tab').forEach(el=>el.classList.remove('active'));
  document.getElementById('dtab-'+t).classList.add('active');btn.classList.add('active');
  if(t==='champions')renderChampionsTab();
  if(t==='performance')renderPerformanceTab();
  if(t==='progression')renderProgressionTab();
  if(t==='profil')renderProfileCards();
  if(t==='main'){renderDesktopTable();renderStats();setTimeout(()=>renderChart('d'),30);}
}

/* ════════════ SETUP ════════════ */
let editProfId=null;
function openSetup(pid){
  editProfId=pid||null;
  document.getElementById('modal-title-txt').textContent=editProfId?'⚙ Modifier':'⚔ Nouveau profil';
  const p=editProfId?S.profiles.find(x=>x.id===editProfId):null;
  if(p&&p.setup){document.getElementById('s-name').value=p.setup.name||'';document.getElementById('s-queue').value=p.setup.queue||'Solo/Duo';document.getElementById('s-season').value=p.setup.season||'Split 1';document.getElementById('s-rank').value=p.setup.initialRank?.rank||'Gold';document.getElementById('s-div').value=p.setup.initialRank?.div||'IV';document.getElementById('s-lp').value=p.setup.initialRank?.lp||0;document.getElementById('s-goal').value=p.setup.goalRank||'Platinum';}
  else{document.getElementById('s-name').value='';document.getElementById('s-season').value='Split 1';document.getElementById('s-lp').value=0;}
  document.getElementById('setup-modal').classList.remove('hidden');
}
function openNewProfile(){openSetup(null);}
function saveSetup(){
  const rank=document.getElementById('s-rank').value,div=document.getElementById('s-div').value,lp=parseInt(document.getElementById('s-lp').value)||0;
  const setup={name:document.getElementById('s-name').value.trim()||'Invocateur',queue:document.getElementById('s-queue').value,season:document.getElementById('s-season').value.trim()||'Split 1',goalRank:document.getElementById('s-goal').value,initialRank:{rank,div,lp}};
  if(editProfId){const p=S.profiles.find(x=>x.id===editProfId);if(p)p.setup=setup;}
  else{const np={id:'p_'+Date.now(),setup,games:[],currentRank:{rank,div,lp}};S.profiles.push(np);S.activeProfileId=np.id;}
  save();document.getElementById('setup-modal').classList.add('hidden');render();
}
function switchProfile(id){S.activeProfileId=id;save();render();renderProfileCards();if(window.innerWidth<=900)mGoPage('home');}
function deleteProfile(id){
  if(S.profiles.length<=1){alert('Impossible de supprimer le dernier profil.');return;}
  if(!confirm('Supprimer ce profil ?'))return;
  S.profiles=S.profiles.filter(p=>p.id!==id);
  if(S.activeProfileId===id)S.activeProfileId=S.profiles[0]?.id||null;
  save();render();renderProfileCards();
}

/* ════════════ EDIT GAME ════════════ */
let editGameId=null;
function openEditModal(id){
  const prof=ap();if(!prof)return;
  const g=prof.games.find(x=>x.id===id);if(!g)return;
  editGameId=id;
  editPendingScreenshot=null;
  document.getElementById('e-result').value=g.result;
  document.getElementById('e-lp').value=g.lpChange;
  document.getElementById('e-champ').value=g.champion||'';
  document.getElementById('e-matchup').value=g.matchup||'';
  document.getElementById('e-role').value=g.role||'Jungle';
  document.getElementById('e-k').value=g.k||0;
  document.getElementById('e-d').value=g.d||0;
  document.getElementById('e-a').value=g.a||0;
  document.getElementById('e-teamk').value=g.teamk||'';
  document.getElementById('e-csm').value=g.csm||'';
  document.getElementById('e-vs').value=g.vs||'';
  document.getElementById('e-dmg').value=g.dmg||'';
  document.getElementById('e-note').value=g.note||'';
  document.getElementById('e-draft').value=g.draft||'';
  document.getElementById('e-comment').value=g.comment||'';
  const prev=document.getElementById('e-screenshot-preview');
  if(prev){
    if(g.screenshot){
      prev.innerHTML=`<img src="${g.screenshot}" style="height:40px;border-radius:4px;border:1px solid var(--border2);cursor:pointer" onclick="openImg('${g.screenshot}')"/> <span style="color:var(--text2);font-size:11px;font-family:'Share Tech Mono',monospace">Image existante</span>`;
    }else{
      prev.textContent='Aucun screenshot';
    }
  }
  document.getElementById('edit-modal').classList.remove('hidden');
}
function closeEditModal(){document.getElementById('edit-modal').classList.add('hidden');editGameId=null;}
function saveEdit(){
  const prof=ap();if(!prof||!editGameId)return;
  const idx=prof.games.findIndex(g=>g.id===editGameId);if(idx===-1)return;
  const g=prof.games[idx];
  const newResult=document.getElementById('e-result').value;
  const newLpChange=parseInt(document.getElementById('e-lp').value)||0;
  const k=parseInt(document.getElementById('e-k').value)||0;
  const d=parseInt(document.getElementById('e-d').value)||0;
  const a=parseInt(document.getElementById('e-a').value)||0;
  const teamk=parseInt(document.getElementById('e-teamk').value)||null;
  const kp=teamk?Math.round((k+a)/teamk*100):null;
  prof.games[idx]={...g,result:newResult,lpChange:newLpChange,champion:document.getElementById('e-champ').value.trim()||g.champion,matchup:document.getElementById('e-matchup').value.trim(),role:document.getElementById('e-role').value,k,d,a,teamk,kp,kdaRatio:d===0?Infinity:(k+a)/d,csm:parseFloat(document.getElementById('e-csm').value)||null,vs:parseInt(document.getElementById('e-vs').value)||null,dmg:parseFloat(document.getElementById('e-dmg').value)||null,note:parseInt(document.getElementById('e-note').value)||null,draft:document.getElementById('e-draft').value.trim(),comment:document.getElementById('e-comment').value.trim(),screenshot:editPendingScreenshot!==null?editPendingScreenshot:g.screenshot};
  if(idx===prof.games.length-1){
    const prev=prof.setup.initialRank;
    const total=Math.max(0,r2lp(prev.rank,prev.div,prev.lp)+newLpChange);
    prof.games[idx].rankAfter=lp2r(total);
  }else{
    const prevGame=prof.games[idx+1];
    const prevLP=r2lp(prevGame.rankAfter.rank,prevGame.rankAfter.div,prevGame.rankAfter.lp);
    prof.games[idx].rankAfter=lp2r(Math.max(0,prevLP+newLpChange));
  }
  prof.currentRank={...prof.games[0].rankAfter};
  save();closeEditModal();render();
}

/* ════════════ FORM ════════════ */
function setResult(r){
  S.formResult=r;
  ['win','loss'].forEach(x=>{
    ['m-rb-'+x,'d-rb-'+x].forEach(id=>{const el=document.getElementById(id);if(el)el.classList.toggle('active',x===r);});
  });
}

function addGame(src){
  if(!ap()){alert('Créez un profil d\'abord !');openSetup();return;}
  const px=src==='mobile'?'m':'d',prof=ap();
  const result=S.formResult;
  const lpRaw=parseInt(document.getElementById(px+'-f-lp').value)||0;
  const champ=document.getElementById(px+'-f-champ').value.trim()||'Nasus';
  const matchup=document.getElementById(px+'-f-matchup').value.trim()||'';
  const role=document.getElementById(px+'-f-role').value;
  const k=parseInt(document.getElementById(px+'-f-k').value)||0;
  const d=parseInt(document.getElementById(px+'-f-d').value)||0;
  const a=parseInt(document.getElementById(px+'-f-a').value)||0;
  const teamk=parseInt(document.getElementById(px+'-f-teamk').value)||null;
  const kp=teamk?Math.round((k+a)/teamk*100):null;
  const csm=parseFloat(document.getElementById(px+'-f-csm').value)||null;
  const vs=parseInt(document.getElementById(px+'-f-vs').value)||null;
  const dmg=parseFloat(document.getElementById(px+'-f-dmg').value)||null;
  const note=parseInt(document.getElementById(px+'-f-note').value)||null;
  const draft=document.getElementById(px+'-f-draft').value.trim();
  const comment=document.getElementById(px+'-f-comment').value.trim();
  const lpChange=result==='win'?Math.abs(lpRaw):-Math.abs(lpRaw);
  let total=r2lp(prof.currentRank.rank,prof.currentRank.div,prof.currentRank.lp);
  total=Math.max(0,total+lpChange);
  const newRank=lp2r(total);
  const kdaRatio=d===0?Infinity:(k+a)/d;
  prof.games.unshift({id:Date.now(),date:new Date().toLocaleDateString('fr-FR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}),ts:Date.now(),champion:champ,matchup,role,result,lpChange,rankBefore:{...prof.currentRank},rankAfter:{...newRank},k,d,a,teamk,kp,kdaRatio,csm,vs,dmg,note,draft,comment,screenshot:pendingScreenshot||null});
  prof.currentRank=newRank;
  [px+'-f-matchup',px+'-f-k',px+'-f-d',px+'-f-a',px+'-f-teamk',px+'-f-csm',px+'-f-vs',px+'-f-dmg',px+'-f-note',px+'-f-draft',px+'-f-comment'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  document.getElementById(px+'-f-lp').value='20';
  const prev=document.getElementById(px+'-screenshot-preview');if(prev)prev.textContent='Aucun screenshot';
  pendingScreenshot=null;
  save();render();
  if(src==='mobile')mGoPage('home');
}

function deleteGame(id){
  if(!confirm('Supprimer ?'))return;
  const prof=ap();if(!prof)return;
  const idx=prof.games.findIndex(g=>g.id===id);if(idx===-1)return;
  prof.games.splice(idx,1);
  prof.currentRank=prof.games.length>0?{...prof.games[0].rankAfter}:{...prof.setup.initialRank};
  save();render();
}
function clearAll(){
  if(!confirm('Réinitialiser l\'historique du profil actif ?'))return;
  const prof=ap();if(!prof)return;
  prof.games=[];
  if(prof.setup?.initialRank)prof.currentRank={...prof.setup.initialRank};
  save();render();
}
