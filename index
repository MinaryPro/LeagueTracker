/* ════════════ COMPUTE ════════════ */
function computeStats(games){
  const realG=games.filter(g=>g.result!=='remake'),wins=games.filter(g=>g.result==='win');
  const wr=realG.length>0?Math.round(wins.length/realG.length*100):null;
  const lpNet=games.reduce((s,g)=>s+g.lpChange,0);
  const kdaG=games.filter(g=>isFinite(g.kdaRatio));
  const avgKda=kdaG.length>0?(kdaG.reduce((s,g)=>s+g.kdaRatio,0)/kdaG.length).toFixed(2):'—';
  const csG=games.filter(g=>g.csm);const avgCs=csG.length>0?(csG.reduce((s,g)=>s+g.csm,0)/csG.length).toFixed(1):'—';
  const vsG=games.filter(g=>g.vs);const avgVs=vsG.length>0?Math.round(vsG.reduce((s,g)=>s+g.vs,0)/vsG.length):'—';
  const dmgG=games.filter(g=>g.dmg);const avgDmg=dmgG.length>0?(dmgG.reduce((s,g)=>s+g.dmg,0)/dmgG.length).toFixed(1):'—';
  const kpG=games.filter(g=>g.kp!==null&&g.kp!==undefined);const avgKp=kpG.length>0?Math.round(kpG.reduce((s,g)=>s+g.kp,0)/kpG.length):'—';
  const noteG=games.filter(g=>g.note);const avgNote=noteG.length>0?(noteG.reduce((s,g)=>s+g.note,0)/noteG.length).toFixed(1):'—';
  let bestWin=0,worstLoss=0,curS=0,curType=null,curStreak=0,curStreakType=null;
  [...games].reverse().forEach(g=>{if(g.result==='remake')return;if(g.result===curType)curS++;else{curS=1;curType=g.result;}if(curType==='win')bestWin=Math.max(bestWin,curS);if(curType==='loss')worstLoss=Math.max(worstLoss,curS);});
  for(let i=0;i<games.length;i++){if(i===0){curStreakType=games[i].result;curStreak=1;}else if(games[i].result===curStreakType)curStreak++;else break;}
  const streakStr=curStreak>1?(curStreakType==='win'?`${curStreak}W`:`${curStreak}L`):'—';
  return{wr,lpNet,avgKda,avgCs,avgVs,avgDmg,avgKp,avgNote,bestWin,worstLoss,streakStr};
}

