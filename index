      <div class="hdr-cfg" onclick="openSetup()" title="Config">⚙</div>
    </div>
  </div>
  <div class="hdr-row2" id="hdr-row2">
    <div style="display:flex;gap:5px">
      <button class="hdr-action-btn" onclick="exportData()">💾 Sauver</button>
      <button class="hdr-action-btn" onclick="importData()">📂 Restaurer</button>
    </div>
  </div>
</header>

