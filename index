          <div class="fgroup"><label class="flabel">Vision score</label><input class="finput" id="m-f-vs" type="number" placeholder="22" min="0" inputmode="numeric"/></div>
          <div class="fgroup"><label class="flabel">Dégâts (k)</label><input class="finput" id="m-f-dmg" type="number" placeholder="18.5" step="0.1" inputmode="decimal"/></div>
          <div class="fgroup"><label class="flabel">Note /10</label><input class="finput" id="m-f-note" type="number" placeholder="7" min="1" max="10" inputmode="numeric"/></div>
