        <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px">
          <div id="m-goal-label" style="font-family:'Rajdhani',sans-serif;font-size:20px;font-weight:700;color:#3cb8a8">Platinum</div>
          <div id="m-goal-missing" style="font-family:'Share Tech Mono',monospace;font-size:12px;color:var(--text2)">—</div>
